{
  "name": "text-based-browser-game-1",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "format": "prettier --check . && pnpm format:package-json --check",
    "format:fix": "prettier --write --list-different . && pnpm format:package-json",
    "format:package-json": "sort-package-json package.json shared/eslint/package.json frontend/package.json backend/package.json",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*package.json": "sort-package-json",
    "*.{md,json,yml,yaml,css,scss}": "prettier --write",
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "prettier": {
    "printWidth": 140,
    "semi": false
  },
  "devDependencies": {
    "@shared/eslint": "file:./shared/eslint",
    "eslint": "9.39.4",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "sort-package-json": "3.6.1"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
